---
import { SITE } from "@/lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-graphite-800/80 px-[var(--gutter)] py-14">
  <div
    class="mx-auto flex max-w-content flex-wrap items-start justify-between gap-8 font-mono text-[11px] uppercase tracking-widest text-graphite-300"
  >
    <div class="max-w-xs">
      <div class="mb-3 text-graphite-50">{SITE.name}</div>
      <p class="text-[11px] normal-case leading-relaxed tracking-normal text-graphite-300">
        Houston-based. Building circuits, small businesses, and championship robots — one working
        document at a time.
      </p>
    </div>

    <div>
      <div class="mb-3 text-graphite-100">Direct</div>
      <ul class="space-y-1.5 normal-case tracking-normal">
        <li>
          <a
            class="text-graphite-200 underline decoration-graphite-600 underline-offset-4 hover:text-signal-400 hover:decoration-signal-400"
            href={`mailto:${SITE.email}`}>{SITE.email}</a
          >
        </li>
        <li>
          <a
            class="text-graphite-200 underline decoration-graphite-600 underline-offset-4 hover:text-signal-400 hover:decoration-signal-400"
            href={SITE.phoneHref}>{SITE.phone}</a
          >
        </li>
        <li class="text-graphite-300">{SITE.location} · {SITE.coords}</li>
      </ul>
    </div>

    <div>
      <div class="mb-3 text-graphite-100">Nav</div>
      <ul class="space-y-1.5">
        <li><a class="hover:text-graphite-50" href="/">Home</a></li>
        <li><a class="hover:text-graphite-50" href="/work/">Work</a></li>
        <li><a class="hover:text-graphite-50" href="/about/">About</a></li>
        <li><a class="hover:text-graphite-50" href="/contact/">Contact</a></li>
      </ul>
    </div>
  </div>

  <div
    class="mx-auto mt-10 flex max-w-content flex-wrap justify-between gap-3 font-mono text-[10px] uppercase tracking-widest text-graphite-400"
  >
    <div>© {year} {SITE.name} · A working document</div>
    <div>Penn State EE '30 · Class of 2030</div>
  </div>
</footer>
