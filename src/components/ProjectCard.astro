---
import type { CollectionEntry } from "astro:content";
import { CATEGORIES } from "@/lib/site";

interface Props {
  project: CollectionEntry<"projects">;
  variant?: "featured" | "grid";
  index?: number;
}
const { project, variant = "grid", index = 0 } = Astro.props;
const data = project.data;
const category = CATEGORIES.find((c) => c.slug === data.category);
const href = `/work/${project.slug}/`;
const codeLabel = `P.${String(index + 1).padStart(2, "0")}`;
---

{
  variant === "featured" ? (
    <article class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1.15fr_1fr] lg:gap-16">
      <a
        href={href}
        class="card-hover group relative block aspect-[5/4] overflow-hidden rounded-2xl border border-graphite-800 bg-graphite-900"
      >
        {data.cover ? (
          <img
            src={
              typeof data.cover === "object" && "src" in data.cover
                ? (data.cover as { src: string }).src
                : ""
            }
            alt={
              typeof data.cover === "object" && "alt" in data.cover
                ? (data.cover as { alt: string }).alt
                : data.title
            }
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
          />
        ) : (
          <div class="absolute inset-0 grid place-items-center bg-gradient-to-br from-graphite-800 to-graphite-950">
            <div class="text-center">
              <div class="mb-2 font-mono text-[10px] uppercase tracking-widest text-graphite-300">
                {codeLabel} · Cover pending
              </div>
              <div class="font-display text-[clamp(1.5rem,3vw,2.2rem)] font-bold leading-none text-graphite-100">
                {data.title}
              </div>
            </div>
          </div>
        )}
        <span
          class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-signal-500/60 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          aria-hidden="true"
        />
      </a>

      <div>
        <div class="mb-5 flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-widest">
          <span class="rounded-full border border-signal-500/40 bg-signal-500/10 px-2.5 py-1 text-signal-400">
            {codeLabel}
          </span>
          <span class="text-graphite-300">·</span>
          <span class="text-graphite-300">{data.year}</span>
          {category && (
            <>
              <span class="text-graphite-300">·</span>
              <span class="text-graphite-200">{category.label}</span>
            </>
          )}
        </div>
        <h3 class="mb-3 font-display text-[clamp(2rem,3.6vw,3.2rem)] font-bold leading-[1.02] tracking-tightest">
          <a href={href} class="transition-colors hover:text-signal-400">
            {data.title}
          </a>
        </h3>
        <div class="mb-6 font-mono text-xs uppercase tracking-widest text-graphite-300">
          {data.role}
        </div>
        <p class="mb-7 max-w-[46ch] text-[17px] leading-[1.7] text-graphite-200">{data.summary}</p>
        <div class="flex flex-wrap gap-2">
          {data.technologies.slice(0, 4).map((t: string) => (
            <span class="rounded-full border border-graphite-700 bg-white/[0.02] px-3 py-1.5 font-mono text-[10px] uppercase tracking-wider text-graphite-200">
              {t}
            </span>
          ))}
          {data.hardware.slice(0, 3).map((h: string) => (
            <span class="rounded-full border border-graphite-700 bg-white/[0.02] px-3 py-1.5 font-mono text-[10px] uppercase tracking-wider text-graphite-300">
              {h}
            </span>
          ))}
        </div>
        <div class="mt-8">
          <a
            href={href}
            class="inline-flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-signal-400 transition-colors hover:text-signal-300"
          >
            <span>Read case study</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </article>
  ) : (
    <a
      href={href}
      class="card-hover group relative flex flex-col gap-3 rounded-2xl border border-graphite-800 bg-gradient-to-b from-graphite-900 to-graphite-950 p-7"
    >
      <div class="flex items-center justify-between font-mono text-[11px] uppercase tracking-widest text-graphite-300">
        <span class="rounded border border-graphite-700 bg-white/[0.02] px-2 py-0.5 text-graphite-200">
          {codeLabel}
        </span>
        <span>{category?.short ?? data.category}</span>
      </div>
      <h3 class="font-display text-[1.6rem] font-bold leading-tight tracking-tight text-graphite-50 transition-colors group-hover:text-signal-400">
        {data.title}
      </h3>
      <p class="text-[15px] leading-[1.65] text-graphite-200">{data.summary}</p>
      <div class="mt-auto flex items-center gap-2 pt-3 font-mono text-[10px] uppercase tracking-widest text-graphite-300">
        <span>{data.year}</span>
        <span>·</span>
        <span>{data.role}</span>
      </div>
    </a>
  )
}
