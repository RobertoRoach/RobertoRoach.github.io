---
// A hand-drawn circuit / waveform motif used as the hero signature and
// occasionally as a section accent. Purely decorative; hidden from screen
// readers. The animation is stroke-dash "routing" that respects reduced-motion.
interface Props {
  class?: string;
  variant?: "hero" | "wave" | "compact";
}
const { class: className = "", variant = "hero" } = Astro.props;
---

{
  variant === "hero" && (
    <svg
      class:list={["h-auto w-full", className]}
      viewBox="0 0 720 460"
      role="img"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <pattern id="cm-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path
            d="M 40 0 L 0 0 0 40"
            fill="none"
            stroke="rgba(255,255,255,0.05)"
            stroke-width="1"
          />
        </pattern>
        <linearGradient id="cm-signal" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0" stop-color="#FF6C5F" stop-opacity="0" />
          <stop offset="0.35" stop-color="#FF6C5F" stop-opacity="1" />
          <stop offset="1" stop-color="#DC1F13" stop-opacity="1" />
        </linearGradient>
      </defs>

      <rect width="720" height="460" fill="url(#cm-grid)" />

      {/* corner registration marks */}
      <g stroke="rgba(255,255,255,0.2)" stroke-width="1" fill="none">
        <path d="M 14 14 L 30 14 M 14 14 L 14 30" />
        <path d="M 706 14 L 690 14 M 706 14 L 706 30" />
        <path d="M 14 446 L 30 446 M 14 446 L 14 430" />
        <path d="M 706 446 L 690 446 M 706 446 L 706 430" />
      </g>

      {/* main routed traces */}
      <g fill="none" stroke-linecap="square" stroke-linejoin="miter">
        <path
          class="cm-trace"
          d="M 20 230 L 200 230 L 200 130 L 380 130"
          stroke="url(#cm-signal)"
          stroke-width="1.6"
          style="filter: drop-shadow(0 0 6px rgba(255,108,95,0.55));"
        />
        <path
          class="cm-trace cm-d1"
          d="M 380 130 L 380 90 L 560 90 L 560 220"
          stroke="url(#cm-signal)"
          stroke-width="1.6"
          style="filter: drop-shadow(0 0 6px rgba(255,108,95,0.55));"
        />
        <path
          class="cm-trace cm-d2"
          d="M 20 230 L 100 230 L 100 340 L 260 340 L 260 300 L 440 300"
          stroke="rgba(255,255,255,0.32)"
          stroke-width="1"
        />
        <path
          class="cm-trace cm-d3"
          d="M 440 300 L 620 300 L 620 380 L 700 380"
          stroke="rgba(255,255,255,0.32)"
          stroke-width="1"
        />
      </g>

      {/* nodes */}
      <g>
        <circle cx="200" cy="230" r="4" fill="#08080A" stroke="#FF6C5F" stroke-width="1.4" />
        <circle cx="380" cy="130" r="4" fill="#08080A" stroke="#FF6C5F" stroke-width="1.4" />
        <circle
          cx="560"
          cy="220"
          r="5"
          fill="#FF3B2F"
          stroke="#FF3B2F"
          style="filter: drop-shadow(0 0 8px rgba(255,59,47,0.7));"
        />
        <circle cx="100" cy="340" r="3" fill="rgba(255,255,255,0.4)" />
        <circle cx="260" cy="300" r="3" fill="rgba(255,255,255,0.4)" />
        <circle cx="620" cy="380" r="3" fill="rgba(255,255,255,0.4)" />
      </g>

      {/* module labels */}
      <g font-family='"JetBrains Mono", monospace' font-size="10" letter-spacing="0.14em">
        <text x="24" y="20" fill="#7A7A85">
          R.R / 01
        </text>
        <text x="696" y="20" text-anchor="end" fill="#FF6C5F">
          SIG · LIVE
        </text>
        <text x="576" y="242" fill="#FF6C5F">
          HUB
        </text>
        <text x="24" y="448" fill="#7A7A85">
          HOU / TX
        </text>
        <text x="696" y="448" text-anchor="end" fill="#7A7A85">
          V2026
        </text>
      </g>
    </svg>
  )
}

{
  variant === "wave" && (
    <svg
      class:list={["h-auto w-full", className]}
      viewBox="0 0 900 120"
      role="img"
      aria-hidden="true"
      focusable="false"
    >
      <path
        class="cm-trace"
        d="M 0 60 L 40 60 L 52 20 L 68 100 L 84 40 L 108 60 L 160 60 L 172 24 L 188 96 L 204 44 L 236 60 L 300 60 L 314 30 L 330 90 L 348 60 L 420 60 L 434 22 L 450 98 L 468 44 L 500 60 L 600 60 L 616 30 L 632 92 L 650 44 L 690 60 L 780 60 L 794 28 L 810 92 L 828 44 L 860 60 L 900 60"
        fill="none"
        stroke="url(#cm-signal)"
        stroke-width="1.6"
        style="filter: drop-shadow(0 0 6px rgba(255,108,95,0.55));"
      />
      <defs>
        <linearGradient id="cm-signal" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0" stop-color="#FF6C5F" stop-opacity="0" />
          <stop offset="0.35" stop-color="#FF6C5F" stop-opacity="1" />
          <stop offset="1" stop-color="#DC1F13" stop-opacity="1" />
        </linearGradient>
      </defs>
    </svg>
  )
}

{
  variant === "compact" && (
    <svg
      class:list={["h-auto w-full", className]}
      viewBox="0 0 200 200"
      role="img"
      aria-hidden="true"
      focusable="false"
    >
      <g fill="none" stroke="rgba(255,255,255,0.32)" stroke-width="1">
        <path d="M 10 100 L 80 100 L 80 40 L 150 40" />
        <path d="M 80 100 L 80 160 L 150 160" />
        <path d="M 80 100 L 190 100" />
      </g>
      <g>
        <circle
          cx="80"
          cy="100"
          r="4"
          fill="#FF3B2F"
          style="filter: drop-shadow(0 0 6px rgba(255,59,47,0.7));"
        />
        <circle cx="150" cy="40" r="3" fill="none" stroke="rgba(255,255,255,0.5)" />
        <circle cx="150" cy="160" r="3" fill="none" stroke="rgba(255,255,255,0.5)" />
        <circle cx="190" cy="100" r="3" fill="none" stroke="rgba(255,255,255,0.5)" />
      </g>
    </svg>
  )
}

<style>
  .cm-trace {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: cm-draw 2s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }
  .cm-d1 {
    animation-delay: 0.3s;
  }
  .cm-d2 {
    animation-delay: 0.6s;
  }
  .cm-d3 {
    animation-delay: 0.9s;
  }
  @keyframes cm-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cm-trace {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
