---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import CircuitMotif from "@/components/CircuitMotif.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE, DISCIPLINE_PATHWAYS } from "@/lib/site";

const all = await getCollection("projects");

const featuredRAR = all.filter((p) => p.data.category === "rar-technologies" && p.data.featured);
const featuredEngineering = all
  .filter(
    (p) =>
      p.data.featured &&
      (p.data.category === "robotics-and-embedded-systems" ||
        p.data.category === "teaching-and-leadership"),
  )
  .slice(0, 2);
---

<BaseLayout title="Engineer · Founder · Coach">
  {/* ==================== HERO ==================== */}
  <header
    class="bg-radial-signal relative overflow-hidden px-[var(--gutter)] pb-24 pt-36 md:pb-32 md:pt-44"
  >
    <div class="bg-grid absolute inset-0 opacity-70" aria-hidden="true"></div>

    <div
      class="relative z-10 mx-auto grid max-w-content grid-cols-1 items-end gap-14 lg:grid-cols-[minmax(0,1fr)_minmax(0,420px)] lg:gap-24"
    >
      <div>
        <div class="mb-10 flex flex-wrap items-baseline gap-4">
          <span class="mono-label flex items-center gap-2.5">
            <span class="status-led"></span>
            R.R / 01 · System online
          </span>
          <span class="mono-label text-graphite-400">
            {SITE.location} · {SITE.coords}
          </span>
        </div>

        <h1
          class="mb-8 font-display text-[clamp(3.2rem,10vw,7.5rem)] font-extrabold leading-[0.9] tracking-tightest"
        >
          I build <em class="text-signal-gradient not-italic">systems</em>
          <br />that move,
          <br />think, <em class="italic text-graphite-100">& connect.</em>
          <span
            aria-hidden="true"
            class="ml-2 inline-block h-[0.75em] w-[0.14em] translate-y-[-6px] animate-caret bg-signal-500 align-middle shadow-signal"
          ></span>
        </h1>

        <p
          class="mb-6 max-w-2xl font-display text-[clamp(1.2rem,2vw,1.6rem)] font-medium leading-[1.4] text-graphite-100"
        >
          <span class="text-signal-400">Electrical engineering student</span>, robotics educator,
          web developer, and founder of
          <span class="text-signal-400">RAR Technologies</span>.
        </p>

        <p class="mb-10 max-w-xl text-[17px] leading-[1.7] text-graphite-200">
          Based in {SITE.location}. Building circuits, small businesses, and championship robots —
          one working document at a time.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/work/" class="btn btn-primary">
            <span>View selected work</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href="/contact/" class="btn">Get in touch</a>
        </div>
      </div>

      <aside
        class="relative rounded-2xl border border-graphite-800 bg-graphite-900/40 p-6 backdrop-blur-sm"
      >
        <div
          class="mb-4 flex items-center justify-between font-mono text-[10px] uppercase tracking-widest text-graphite-300"
        >
          <span class="text-signal-400">SIG / R.R · 01</span>
          <span class="flex items-center gap-2">
            <span class="status-led"></span>Live
          </span>
        </div>

        <CircuitMotif variant="hero" class="mb-4" />

        <dl
          class="grid grid-cols-[1fr_auto] gap-x-4 gap-y-1.5 font-mono text-[11px] uppercase tracking-widest"
        >
          <dt class="text-graphite-400">Studio</dt>
          <dd class="text-signal-400">RAR Technologies</dd>
          <dt class="text-graphite-400">Coach</dt>
          <dd class="text-graphite-100">OM · Worlds</dd>
          <dt class="text-graphite-400">Stack</dt>
          <dd class="text-graphite-100">EE · Embedded</dd>
          <dt class="text-graphite-400">Lang</dt>
          <dd class="text-graphite-100">EN · ES</dd>
          <dt class="text-graphite-400">Next</dt>
          <dd class="text-graphite-100">PSU EE '30</dd>
        </dl>
      </aside>
    </div>
  </header>

  {/* ==================== DATA STRIP ==================== */}
  <div class="border-y border-graphite-800 bg-graphite-900/40 px-[var(--gutter)] py-5">
    <div
      class="mx-auto flex max-w-content flex-wrap items-center gap-x-10 gap-y-3 font-mono text-[11px] uppercase tracking-widest text-graphite-400"
    >
      <span class="flex items-center gap-2.5">
        <span class="text-graphite-300">Status</span>
        <span class="flex items-center gap-2 text-signal-400"
          ><span class="status-led"></span>Active</span
        >
      </span>
      <span
        ><span class="text-graphite-300">Studio </span><span class="text-signal-400">RAR TECH</span
        ></span
      >
      <span
        ><span class="text-graphite-300">Base </span><span class="text-graphite-100">HOU / TX</span
        ></span
      >
      <span
        ><span class="text-graphite-300">Lang </span><span class="text-graphite-100">EN · ES</span
        ></span
      >
      <span class="ml-auto"
        ><span class="text-graphite-300">Sig </span><span class="text-graphite-100">R.R / 01</span
        ></span
      >
    </div>
  </div>

  {/* ==================== IDENTITY / DISCIPLINES ==================== */}
  <section class="px-[var(--gutter)] py-28">
    <div class="mx-auto max-w-content">
      <div class="mb-14 grid grid-cols-1 items-baseline gap-8 md:grid-cols-[220px_1fr]">
        <div class="mono-label reveal">D · Three disciplines</div>
        <h2
          class="reveal reveal-1 font-display text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1.02] tracking-tightest"
        >
          Three overlapping ways I <em class="text-signal-gradient not-italic"
            >think about a problem.</em
          >
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          DISCIPLINE_PATHWAYS.map((p, i) => (
            <a
              href={p.href}
              class:list={[
                "reveal card-hover group relative flex min-h-[280px] flex-col justify-between overflow-hidden rounded-2xl border border-graphite-800 bg-gradient-to-b from-graphite-900 to-graphite-950 p-8",
                i === 1 && "md:translate-y-6",
                i === 2 && "md:translate-y-3",
                `reveal-${(i % 3) + 1}`,
              ]}
            >
              <div>
                <div class="mono-label mb-4 text-graphite-400">
                  <span class="text-signal-400">0{i + 1}</span> / {p.label}
                </div>
                <div class="mb-4 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold leading-[1.02] tracking-tightest text-graphite-50 transition-colors group-hover:text-signal-400">
                  {p.title}
                </div>
                <p class="text-[15px] leading-[1.65] text-graphite-200">{p.body}</p>
              </div>
              <div class="mt-8 flex items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-graphite-300">
                <span>Explore</span>
                <span class="h-px flex-1 bg-graphite-700 transition-colors group-hover:bg-signal-500" />
                <span aria-hidden="true">→</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* ==================== SELECTED RAR ==================== */}
  {
    featuredRAR.length > 0 && (
      <>
        <div class="divider" aria-hidden="true">
          <span class="tick">◆</span>
          <span>Selected RAR work</span>
          <span class="line" />
          <span>R.01</span>
        </div>
        <section class="px-[var(--gutter)] py-24">
          <div class="mx-auto max-w-content">
            <div class="mb-14 grid grid-cols-1 items-baseline gap-8 md:grid-cols-[220px_1fr]">
              <div class="mono-label reveal">R · Studio</div>
              <h2 class="reveal reveal-1 font-display text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1.02] tracking-tightest">
                The studio, from <em class="text-signal-gradient not-italic">the inside.</em>
              </h2>
            </div>
            {featuredRAR.map((p, i) => (
              <div class="reveal">
                <ProjectCard project={p} variant="featured" index={i} />
              </div>
            ))}
          </div>
        </section>
      </>
    )
  }

  {/* ==================== SELECTED ENGINEERING ==================== */}
  {
    featuredEngineering.length > 0 && (
      <>
        <div class="divider" aria-hidden="true">
          <span class="tick">◆</span>
          <span>Selected engineering</span>
          <span class="line" />
          <span>0{featuredEngineering.length} pieces</span>
        </div>
        <section class="px-[var(--gutter)] py-24">
          <div class="mx-auto flex max-w-content flex-col gap-24">
            <div class="grid grid-cols-1 items-baseline gap-8 md:grid-cols-[220px_1fr]">
              <div class="mono-label reveal">P · Engineering</div>
              <h2 class="reveal reveal-1 font-display text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1.02] tracking-tightest">
                Engineering work worth <em class="text-signal-gradient not-italic">showing.</em>
              </h2>
            </div>

            {featuredEngineering.map((p, i) => (
              <div class="reveal">
                <ProjectCard project={p} variant="featured" index={i + 1} />
              </div>
            ))}
          </div>
        </section>
      </>
    )
  }

  {/* ==================== CAPABILITIES ==================== */}
  <div class="divider" aria-hidden="true">
    <span class="tick">◆</span>
    <span>Technical capabilities</span>
    <span class="line"></span>
    <span>The stack</span>
  </div>
  <section class="px-[var(--gutter)] py-24">
    <div class="mx-auto max-w-content">
      <div class="mb-14 grid grid-cols-1 items-baseline gap-8 md:grid-cols-[220px_1fr]">
        <div class="mono-label reveal">C · Legend</div>
        <h2
          class="reveal reveal-1 font-display text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1.02] tracking-tightest"
        >
          The tools I <em class="text-signal-gradient not-italic">run.</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-12 border-t border-graphite-800 pt-10 md:grid-cols-2">
        <div class="reveal">
          <h4
            class="mb-5 flex items-center gap-3 font-mono text-[11px] font-medium uppercase tracking-widest text-graphite-300"
          >
            <span class="status-led"></span>On the bench
          </h4>
          <div class="flex flex-wrap gap-2">
            {
              [
                "Python",
                "C++",
                "Java",
                "Lua",
                "VEXcode",
                "Arduino",
                "HTML / CSS / JS",
                "Astro",
                "Circuit design",
                "Soldering & rework",
                "Microcontrollers",
                "Sensors & motors",
                "Board-level repair",
                "Rocketry",
              ].map((c) => (
                <span class="rounded-lg border border-graphite-700 bg-graphite-900 px-3 py-2 font-mono text-[11px] uppercase tracking-wider text-graphite-100 transition-colors hover:border-signal-500 hover:bg-signal-500/5">
                  {c}
                </span>
              ))
            }
          </div>
        </div>
        <div class="reveal reveal-1">
          <h4
            class="mb-5 flex items-center gap-3 font-mono text-[11px] font-medium uppercase tracking-widest text-graphite-300"
          >
            <span class="status-led amber"></span>Away from the bench
          </h4>
          <div class="flex flex-wrap gap-2">
            {
              [
                "Bilingual EN / ES",
                "Teaching",
                "Mentorship",
                "Legal translation",
                "Team leadership",
                "Client-facing",
                "Judging",
                "Coaching",
                "Web design",
                "Advertising & brand",
                "Cybersecurity fundamentals",
                "Intro to AI",
              ].map((c) => (
                <span class="rounded-lg border border-graphite-700 bg-graphite-900 px-3 py-2 font-mono text-[11px] uppercase tracking-wider text-graphite-100 transition-colors hover:border-amber-500 hover:bg-amber-500/5">
                  {c}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ==================== TEACHING EVIDENCE ==================== */}
  <div class="divider" aria-hidden="true">
    <span class="tick">◆</span>
    <span>Teaching & leadership</span>
    <span class="line"></span>
    <span>T.01</span>
  </div>
  <section class="px-[var(--gutter)] py-24">
    <div class="mx-auto grid max-w-content grid-cols-1 items-start gap-16 lg:grid-cols-[1fr_1.2fr]">
      <div class="reveal">
        <div class="mono-label mb-4">T · Evidence</div>
        <h2
          class="mb-6 font-display text-[clamp(2.2rem,4.5vw,3.6rem)] font-bold leading-[1.02] tracking-tightest"
        >
          Coach, judge, <em class="text-signal-gradient not-italic">instructor.</em>
        </h2>
        <p class="mb-6 text-[17px] leading-[1.7] text-graphite-200">
          I coached the Odyssey of the Mind team that won <span class="text-signal-400">Worlds</span
          >, judge <span class="text-graphite-100">VEX IQ</span> competitions across Texas, and taught
          robotics + code at
          <span class="text-graphite-100">iCode</span>. Teaching under judged pressure is how I
          stress-test my own engineering — if a student can't repeat back the reasoning, the
          reasoning wasn't clear.
        </p>
        <a
          href="/work/?category=teaching-and-leadership"
          class="inline-flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-signal-400 transition-colors hover:text-signal-300"
        >
          <span>Read teaching case studies</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <ul class="reveal reveal-1 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <li
          class="rounded-2xl border border-graphite-800 bg-graphite-900 p-6 transition-colors hover:border-signal-500/60"
        >
          <div class="mono-label mb-3 text-signal-400">Worlds</div>
          <div class="mb-2 font-display text-2xl font-bold leading-tight text-graphite-50">
            OM Champions
          </div>
          <p class="text-sm leading-snug text-graphite-300">
            Coached the team that won at Odyssey of the Mind World Finals.
          </p>
        </li>
        <li
          class="rounded-2xl border border-graphite-800 bg-graphite-900 p-6 transition-colors hover:border-signal-500/60"
        >
          <div class="mono-label mb-3">Judge</div>
          <div class="mb-2 font-display text-2xl font-bold leading-tight text-graphite-50">
            VEX IQ
          </div>
          <p class="text-sm leading-snug text-graphite-300">
            Judging tournaments across Texas — rubrics from the other side of the table.
          </p>
        </li>
        <li
          class="rounded-2xl border border-graphite-800 bg-graphite-900 p-6 transition-colors hover:border-signal-500/60"
        >
          <div class="mono-label mb-3">Instructor</div>
          <div class="mb-2 font-display text-2xl font-bold leading-tight text-graphite-50">
            iCode
          </div>
          <p class="text-sm leading-snug text-graphite-300">
            Robotics, circuit design, and code (Python, Java, C++, Lua).
          </p>
        </li>
      </ul>
    </div>
  </section>

  {/* ==================== ABOUT SNIPPET ==================== */}
  <section class="px-[var(--gutter)] py-24">
    <div
      class="mx-auto grid max-w-content grid-cols-1 items-center gap-14 lg:grid-cols-[0.85fr_1fr] lg:gap-20"
    >
      <div
        class="reveal relative aspect-[4/5] overflow-hidden rounded-2xl border border-graphite-800 bg-graphite-900"
      >
        <div
          class="absolute inset-x-0 top-0 z-10 flex items-center justify-between p-5 font-mono text-[10px] uppercase tracking-widest text-graphite-300"
        >
          <span class="text-signal-400">R.R / 01</span>
          <span>Subject</span>
        </div>
        <img
          src="/images/roberto.png"
          alt="Portrait of Roberto Roach"
          loading="lazy"
          class="absolute inset-x-0 bottom-0 h-full w-full object-contain object-bottom"
        />
        <div
          class="absolute inset-0 z-[5] bg-gradient-to-t from-graphite-950/70 via-transparent to-transparent"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 z-10 flex items-center justify-between p-5 font-mono text-[10px] uppercase tracking-widest text-graphite-300"
        >
          <span>Houston, TX</span>
          <span class="flex items-center gap-2 text-signal-400"
            ><span class="status-led"></span>Active</span
          >
        </div>
      </div>

      <div class="reveal reveal-1">
        <div class="mono-label mb-4">A · About</div>
        <h2
          class="mb-6 font-display text-[clamp(2rem,4vw,3.2rem)] font-bold leading-[1.02] tracking-tightest"
        >
          I like <em class="text-signal-gradient not-italic">building things.</em>
        </h2>
        <p class="mb-4 text-[17px] leading-[1.75] text-graphite-200">
          I'm seventeen, from Houston, and I've been quietly turning every hobby into a project you
          can point at. <span class="text-graphite-50">RAR Technologies</span> started as a repair bench
          and grew into a small studio that also builds
          <span class="text-signal-400">websites</span> and
          <span class="text-signal-400">advertising</span> for local clients.
        </p>
        <p class="mb-8 text-[17px] leading-[1.75] text-graphite-200">
          The competition robots taught me feedback loops the way school never could. In the fall I
          head to <span class="text-graphite-50">Penn State electrical engineering</span> — class of 2030.
          Consider this page a working document.
        </p>
        <a href="/about/" class="btn">Read the full about</a>
      </div>
    </div>
  </section>

  {/* ==================== CONTACT CTA ==================== */}
  <section
    class="bg-radial-signal relative overflow-hidden px-[var(--gutter)] py-32 text-center md:py-40"
  >
    <div class="bg-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl">
      <div class="mono-label mb-6 flex items-center justify-center gap-2.5">
        <span class="status-led"></span>C.01 · Contact
      </div>
      <h2
        class="mb-6 font-display text-[clamp(3rem,8vw,6.5rem)] font-extrabold leading-[0.95] tracking-tightest"
      >
        Let's <em class="text-signal-gradient not-italic">build</em> something.
      </h2>
      <p class="mx-auto mb-10 max-w-lg text-lg text-graphite-200">
        For a repair job at RAR, a website or ad campaign, a robotics collaboration, or a
        conversation about circuits — the fastest way to reach me is here.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/contact/" class="btn btn-primary">
          <span>Get in touch</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href={`mailto:${SITE.email}`} class="btn">Email direct</a>
      </div>
    </div>
  </section>
</BaseLayout>
