---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE, RAR_PRACTICE, EXPERIENCE } from "@/lib/site";

const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const bySlug = (s: string) => all.find((p) => p.slug === s);

const rarPortfolioSite = bySlug("rar-portfolio-site");
const icode = bySlug("icode-memorial");
const arduinoAudio = bySlug("arduino-embedded-audio");
const vexV5 = bySlug("vex-v5-basketball-robot");
const omCoaching = bySlug("om-worlds-coaching");

// A tight selected-work set for the homepage — the full set lives on /work/.
const selected = [rarPortfolioSite, arduinoAudio, vexV5, icode].filter(
  (p): p is CollectionEntry<"projects"> => p !== undefined,
);
---

<BaseLayout title="Founder · Engineer · Robotics Educator">
  {/* ==================== HERO ==================== */}
  <header class="px-[var(--gutter)] pt-36 md:pt-44">
    <div class="mx-auto max-w-content">
      <div
        class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.4fr_0.6fr] lg:gap-16"
      >
        <div>
          <div class="mono-label mb-8 flex items-center gap-2.5 text-signal-500">
            RAR Technologies / {SITE.location}
          </div>
          <h1
            class="mb-8 font-display text-[clamp(3rem,9vw,7rem)] font-extrabold leading-[0.92] tracking-tightest"
          >
            I build systems<br />that move, think,<br />and <span
              class="text-signal-gradient">connect.</span
            >
          </h1>
          <p class="mb-10 max-w-lg text-[17px] leading-[1.7] text-graphite-300">
            Roberto Andrés Roach — founder of RAR Technologies, building websites, embedded
            electronics, robotics systems, and the technical understanding behind them.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/work/" class="btn btn-primary">View selected work</a>
            <a href="/contact/" class="btn">Contact</a>
          </div>
        </div>

        <div
          class="relative aspect-[3/4] overflow-hidden border border-graphite-800 bg-graphite-800 lg:aspect-auto lg:h-[420px]"
        >
          <img
            src="/images/roberto.png"
            alt="Portrait of Roberto Andrés Roach"
            loading="eager"
            class="absolute inset-x-0 bottom-0 h-full w-full object-contain object-bottom"
          />
        </div>
      </div>
    </div>
  </header>

  {/* ==================== 01 · RAR TECHNOLOGIES ==================== */}
  <section id="rar" class="px-[var(--gutter)] pt-28 md:pt-36">
    <div class="mx-auto max-w-content border-t border-graphite-800 pt-14">
      <div class="mono-label mb-6 text-signal-500">01 / Founder-led practice</div>
      <h2
        class="mb-6 font-display text-[clamp(2.2rem,5vw,4rem)] font-bold leading-[1] tracking-tightest"
      >
        RAR Technologies LLC
      </h2>
      <p class="mb-14 max-w-2xl text-[17px] leading-[1.7] text-graphite-300">
        Founded in 2023 — a single studio combining web development, technology-product
        development, electronics repair, hardware diagnostics, and bilingual client
        communication.
      </p>

      <div class="grid grid-cols-1 gap-px overflow-hidden border border-graphite-800 bg-graphite-800 sm:grid-cols-3">
        {
          RAR_PRACTICE.map((p) => (
            <div class="bg-graphite-900 p-7">
              <div class="mono-label mb-3 text-signal-500">{p.label}</div>
              <p class="text-[15px] leading-[1.6] text-graphite-300">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ==================== 02 · SELECTED WORK ==================== */}
  <section id="work" class="px-[var(--gutter)] pt-28 md:pt-36">
    <div class="mx-auto max-w-content border-t border-graphite-800 pt-14">
      <div class="mb-12 flex flex-wrap items-end justify-between gap-6">
        <div>
          <div class="mono-label mb-6 text-signal-500">02 / Selected work</div>
          <h2
            class="font-display text-[clamp(2.2rem,5vw,4rem)] font-bold leading-[1] tracking-tightest"
          >
            Selected technical work.
          </h2>
        </div>
        <a
          href="/work/"
          class="mono-label text-graphite-300 transition-colors hover:text-signal-400"
        >
          All work →
        </a>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        {
          selected.map((p, i) => (
            <div class="reveal">
              <ProjectCard project={p} variant="grid" index={i} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ==================== 03 · RECOGNITION ==================== */}
  {
    omCoaching && (
      <section id="recognition" class="px-[var(--gutter)] pt-28 md:pt-36">
        <div class="mx-auto max-w-content border-t border-graphite-800 pt-14">
          <div class="mono-label mb-6 text-signal-500">03 / Recognition</div>
          <a href={`/work/${omCoaching.slug}/`} class="group block">
            <h2 class="mb-5 max-w-4xl font-display text-[clamp(2rem,4.5vw,3.4rem)] font-bold leading-[1.05] tracking-tightest transition-colors group-hover:text-signal-400">
              Texas State Champion &amp; World Finals Top&nbsp;10 — Odyssey of the Mind, 2026.
            </h2>
            <p class="max-w-2xl text-[17px] leading-[1.7] text-graphite-300">
              Primary robotics coach for River Oaks Elementary Team A #3999. 1st at the 2026 Texas
              State competition; 7th at the World Finals.
              <span class="mono-label ml-2 text-graphite-400 group-hover:text-signal-400">
                Read the case study →
              </span>
            </p>
          </a>
        </div>
      </section>
    )
  }

  {/* ==================== 04 · EXPERIENCE ==================== */}
  <section id="experience" class="px-[var(--gutter)] pt-28 md:pt-36">
    <div class="mx-auto max-w-content border-t border-graphite-800 pt-14">
      <div class="mono-label mb-6 text-signal-500">04 / Experience</div>
      <h2
        class="mb-12 font-display text-[clamp(2.2rem,5vw,4rem)] font-bold leading-[1] tracking-tightest"
      >
        Technical work with real responsibility.
      </h2>

      <ul>
        {
          EXPERIENCE.map((e) => (
            <li class="grid grid-cols-1 gap-2 border-t border-graphite-800 py-7 md:grid-cols-[240px_1fr] md:gap-8">
              <div>
                <div class="mono-label text-signal-500">{e.org}</div>
                <div class="mono-label mt-1 text-graphite-400">{e.when}</div>
              </div>
              <div>
                <div class="mb-2 font-display text-xl font-bold leading-tight text-graphite-50">
                  {e.role}
                </div>
                <p class="max-w-2xl text-[15px] leading-[1.65] text-graphite-300">{e.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ==================== 05 · CONTACT ==================== */}
  <section id="contact" class="px-[var(--gutter)] pb-32 pt-28 md:pt-40">
    <div class="mx-auto max-w-content border-t border-graphite-800 pt-14">
      <div class="mono-label mb-6 text-signal-500">05 / Contact</div>
      <h2
        class="mb-6 font-display text-[clamp(2.6rem,7vw,5.5rem)] font-extrabold leading-[0.95] tracking-tightest"
      >
        Let's <span class="text-signal-gradient">build</span> something.
      </h2>
      <p class="mb-10 max-w-lg text-[17px] leading-[1.7] text-graphite-300">
        For repair, a website or product build, robotics collaboration, or a conversation about
        circuits. Résumé available on request.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact/" class="btn btn-primary">Get in touch</a>
        <a href={`mailto:${SITE.email}`} class="btn">Email direct</a>
      </div>
    </div>
  </section>
</BaseLayout>
