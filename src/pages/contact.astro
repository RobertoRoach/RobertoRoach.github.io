---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";
---

<BaseLayout
  title="Contact"
  description={`Get in touch with Roberto Andrés Roach — email ${SITE.email} or call ${SITE.phone}. Founder of RAR Technologies, Houston, Texas.`}
>
  <section class="relative min-h-[80dvh] overflow-hidden px-[var(--gutter)] pb-24 pt-36 md:pt-44">
    <div
      class="pointer-events-none absolute inset-0"
      style="background:radial-gradient(1000px 620px at 12% -10%, rgba(225,6,0,0.09), transparent 60%);"
      aria-hidden="true"
    >
    </div>
    <div class="bg-grid absolute inset-0 opacity-60" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-content">
      <div class="mono-label mb-6 flex items-center gap-2.5">
        <span class="status-led"></span>C.01 · Contact
      </div>

      <div class="grid grid-cols-1 gap-16 lg:grid-cols-[1.2fr_1fr] lg:gap-24">
        <div>
          <h1
            class="mb-8 font-display text-[clamp(3rem,9vw,7rem)] font-extrabold leading-[0.9] tracking-tightest"
          >
            Let's <span class="text-signal-gradient">build</span>
            <br />something.
          </h1>
          <p
            class="mb-10 max-w-xl font-display text-[clamp(1.1rem,1.9vw,1.45rem)] font-medium leading-[1.4] text-graphite-100"
          >
            For a repair job at RAR, a website or product build, a robotics coaching collaboration,
            or a conversation about circuits — the fastest way to reach me is here. Résumé available
            on request.
          </p>

          <div class="space-y-4">
            <a
              href={`mailto:${SITE.email}`}
              class="group flex items-center justify-between gap-6 border border-graphite-800 bg-graphite-800/60 p-6 transition-colors hover:border-signal-500/70"
            >
              <div>
                <div class="mono-label mb-2 text-signal-500">Email</div>
                <div class="font-display text-2xl font-bold leading-tight text-graphite-50">
                  {SITE.email}
                </div>
                <div class="mt-1 text-sm text-graphite-300">Reply within 24 hours</div>
              </div>
              <span
                class="font-mono text-xs uppercase tracking-widest text-graphite-300 transition-colors group-hover:text-signal-500"
              >
                Open →
              </span>
            </a>

            <a
              href={SITE.phoneHref}
              class="group flex items-center justify-between gap-6 border border-graphite-800 bg-graphite-800/60 p-6 transition-colors hover:border-signal-500/70"
            >
              <div>
                <div class="mono-label mb-2 text-signal-500">Phone · SMS</div>
                <div class="font-display text-2xl font-bold leading-tight text-graphite-50">
                  {SITE.phone}
                </div>
                <div class="mt-1 text-sm text-graphite-300">
                  Call or text — messages are read before calls are answered.
                </div>
              </div>
              <span
                class="font-mono text-xs uppercase tracking-widest text-graphite-300 transition-colors group-hover:text-signal-500"
              >
                Open →
              </span>
            </a>

            <div class="border border-graphite-800 bg-graphite-800/40 p-6">
              <div class="mono-label mb-2 text-graphite-300">Résumé</div>
              <div class="mb-2 font-display text-xl font-bold leading-tight text-graphite-50">
                Available on request
              </div>
              <p class="text-sm text-graphite-300">
                Email or text for a current résumé PDF. Custom versions available for recruiters and
                admissions officers.
              </p>
            </div>
          </div>
        </div>

        <aside class="border border-graphite-800 bg-graphite-800/60 p-8">
          <div
            class="mb-6 flex items-center justify-between font-mono text-[10px] uppercase tracking-widest text-graphite-300"
          >
            <span class="text-signal-500">Compose · MAIL / OUT</span>
            <span class="flex items-center gap-2">
              <span class="status-led"></span>Ready
            </span>
          </div>
          <form
            id="compose"
            class="space-y-5"
            action={`mailto:${SITE.email}`}
            method="post"
            enctype="text/plain"
          >
            <label class="block">
              <span class="mono-label mb-2 block">Your name</span>
              <input
                required
                name="name"
                type="text"
                class="w-full border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="e.g. Ada Lovelace"
              />
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Your email</span>
              <input
                required
                name="email"
                type="email"
                class="w-full border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="you@domain.com"
              />
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Topic</span>
              <select
                name="subject"
                class="w-full border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors focus:border-signal-500"
              >
                <option value="RAR — Repair job">RAR — Repair job</option>
                <option value="RAR — Website or product">RAR — Website or product</option>
                <option value="Robotics coaching collaboration"
                  >Robotics coaching collaboration</option
                >
                <option value="iCode / teaching">iCode / teaching</option>
                <option value="Recruiting / admissions">Recruiting / admissions</option>
                <option value="Just saying hi">Just saying hi</option>
              </select>
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Message</span>
              <textarea
                required
                name="message"
                rows="5"
                class="w-full resize-none border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="What are we building?"></textarea>
            </label>
            <button type="submit" class="btn btn-primary w-full justify-center">
              <span>Send via mail app</span>
              <span aria-hidden="true">→</span>
            </button>
            <p
              class="text-center font-mono text-[10px] uppercase tracking-widest text-graphite-400"
            >
              Opens your default mail client. No data leaves this page otherwise.
            </p>
          </form>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("compose") as HTMLFormElement | null;
  if (form) {
    form.addEventListener("submit", (e) => {
      const fd = new FormData(form);
      const subject = String(fd.get("subject") ?? "Hello");
      const body = [
        `From: ${fd.get("name")} <${fd.get("email")}>`,
        "",
        String(fd.get("message") ?? ""),
      ].join("\n");
      const href = `mailto:robertoaroachm@gmail.com?subject=${encodeURIComponent(
        subject,
      )}&body=${encodeURIComponent(body)}`;
      e.preventDefault();
      window.location.href = href;
    });
  }
</script>
