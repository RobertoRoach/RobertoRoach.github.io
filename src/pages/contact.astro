---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";
---

<BaseLayout
  title="Contact"
  description={`Get in touch with Roberto Roach — email ${SITE.email} or phone ${SITE.phone}. Houston, TX.`}
>
  <section
    class="bg-radial-signal relative min-h-[80dvh] overflow-hidden px-[var(--gutter)] pb-24 pt-36 md:pt-44"
  >
    <div class="bg-grid absolute inset-0 opacity-60" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-content">
      <div class="mono-label mb-6 flex items-center gap-2.5">
        <span class="status-led"></span>C.01 · Contact
      </div>

      <div class="grid grid-cols-1 gap-16 lg:grid-cols-[1.2fr_1fr] lg:gap-24">
        <div>
          <h1
            class="mb-8 font-display text-[clamp(3rem,9vw,7rem)] font-extrabold leading-[0.9] tracking-tightest"
          >
            Let's <em class="text-signal-gradient not-italic">build</em>
            <br />something.
          </h1>
          <p
            class="mb-10 max-w-xl font-display text-[clamp(1.15rem,2vw,1.5rem)] font-medium leading-[1.4] text-graphite-100"
          >
            For a repair job at RAR, a website or ad campaign, a robotics collaboration, or a
            conversation about circuits — the fastest way to reach me is here.
          </p>

          <div class="space-y-4">
            <a
              href={`mailto:${SITE.email}`}
              class="group flex items-center justify-between gap-6 rounded-2xl border border-graphite-800 bg-graphite-900 p-6 transition-colors hover:border-signal-500/70 hover:bg-signal-500/5"
            >
              <div>
                <div class="mono-label mb-2 text-signal-400">Email</div>
                <div class="font-display text-2xl font-bold leading-tight text-graphite-50">
                  {SITE.email}
                </div>
                <div class="mt-1 text-sm text-graphite-300">Reply within 24 hours</div>
              </div>
              <span
                class="font-mono text-xs uppercase tracking-widest text-graphite-300 transition-colors group-hover:text-signal-400"
              >
                Open →
              </span>
            </a>

            <a
              href={SITE.phoneHref}
              class="group flex items-center justify-between gap-6 rounded-2xl border border-graphite-800 bg-graphite-900 p-6 transition-colors hover:border-signal-500/70 hover:bg-signal-500/5"
            >
              <div>
                <div class="mono-label mb-2 text-signal-400">Phone / SMS</div>
                <div class="font-display text-2xl font-bold leading-tight text-graphite-50">
                  {SITE.phone}
                </div>
                <div class="mt-1 text-sm text-graphite-300">
                  Call or text — I read messages before I answer calls.
                </div>
              </div>
              <span
                class="font-mono text-xs uppercase tracking-widest text-graphite-300 transition-colors group-hover:text-signal-400"
              >
                Open →
              </span>
            </a>
          </div>
        </div>

        {/* Right column — a compose panel that opens the user's mail client. */}
        <aside
          class="rounded-2xl border border-graphite-800 bg-graphite-900/60 p-8 backdrop-blur-sm"
        >
          <div
            class="mb-6 flex items-center justify-between font-mono text-[10px] uppercase tracking-widest text-graphite-300"
          >
            <span class="text-signal-400">Compose · MAIL / OUT</span>
            <span class="flex items-center gap-2">
              <span class="status-led"></span>Ready
            </span>
          </div>
          <form
            id="compose"
            class="space-y-5"
            action={`mailto:${SITE.email}`}
            method="post"
            enctype="text/plain"
          >
            <label class="block">
              <span class="mono-label mb-2 block">Your name</span>
              <input
                required
                name="name"
                type="text"
                class="w-full rounded-lg border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="e.g. Ada Lovelace"
              />
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Your email</span>
              <input
                required
                name="email"
                type="email"
                class="w-full rounded-lg border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="you@domain.com"
              />
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Subject</span>
              <select
                name="subject"
                class="w-full rounded-lg border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors focus:border-signal-500"
              >
                <option value="Repair job">RAR — Repair job</option>
                <option value="Website">RAR — Website / product</option>
                <option value="Advertising">RAR — Advertising / brand</option>
                <option value="Robotics collaboration">Robotics collaboration</option>
                <option value="Coaching / judging">Coaching / judging</option>
                <option value="Just saying hi">Just saying hi</option>
              </select>
            </label>
            <label class="block">
              <span class="mono-label mb-2 block">Message</span>
              <textarea
                required
                name="message"
                rows="5"
                class="w-full resize-none rounded-lg border border-graphite-700 bg-graphite-950 px-4 py-3 font-sans text-base text-graphite-50 outline-none transition-colors placeholder:text-graphite-400 focus:border-signal-500"
                placeholder="What are we building?"></textarea>
            </label>
            <button type="submit" class="btn btn-primary w-full justify-center">
              <span>Send via mail app</span>
              <span aria-hidden="true">→</span>
            </button>
            <p
              class="text-center font-mono text-[10px] uppercase tracking-widest text-graphite-400"
            >
              Opens your default mail client. No data leaves this page otherwise.
            </p>
          </form>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Progressive-enhance: build a nicely-formatted mailto instead of the default
  // text/plain payload that mail apps handle awkwardly.
  const form = document.getElementById("compose") as HTMLFormElement | null;
  if (form) {
    form.addEventListener("submit", (e) => {
      const fd = new FormData(form);
      const subject = String(fd.get("subject") ?? "Hello");
      const body = [
        `From: ${fd.get("name")} <${fd.get("email")}>`,
        "",
        String(fd.get("message") ?? ""),
      ].join("\n");
      const href = `mailto:robertoaroachm@gmail.com?subject=${encodeURIComponent(
        subject,
      )}&body=${encodeURIComponent(body)}`;
      e.preventDefault();
      window.location.href = href;
    });
  }
</script>
