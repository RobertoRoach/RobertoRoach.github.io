---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";
---

<BaseLayout
  title="About"
  description="Roberto Roach — 17, Houston, RAR Technologies founder, robotics coach, and incoming Penn State electrical engineering student."
>
  <section
    class="bg-radial-signal relative overflow-hidden px-[var(--gutter)] pb-16 pt-36 md:pb-24 md:pt-44"
  >
    <div class="bg-grid absolute inset-0 opacity-60" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-content">
      <div class="mono-label mb-6 flex items-center gap-2.5">
        <span class="status-led"></span>A · About
      </div>
      <h1
        class="mb-8 max-w-4xl font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.92] tracking-tightest"
      >
        Engineer. <em class="text-signal-gradient not-italic">Founder.</em> Coach.
      </h1>
      <p
        class="max-w-3xl font-display text-[clamp(1.2rem,2vw,1.6rem)] font-medium leading-[1.35] text-graphite-100"
      >
        Seventeen. Houston, Texas. Building things that move, think, and connect since I could hold
        a screwdriver.
      </p>
    </div>
  </section>

  <section class="px-[var(--gutter)] py-24">
    <div
      class="mx-auto grid max-w-content grid-cols-1 items-start gap-16 lg:grid-cols-[0.9fr_1.1fr] lg:gap-24"
    >
      <div
        class="reveal relative aspect-[4/5] overflow-hidden rounded-2xl border border-graphite-800 bg-graphite-900"
      >
        <div
          class="absolute inset-x-0 top-0 z-10 flex items-center justify-between p-5 font-mono text-[10px] uppercase tracking-widest text-graphite-300"
        >
          <span class="text-signal-400">R.R / 01</span>
          <span>Subject</span>
        </div>
        <img
          src="/images/roberto.png"
          alt="Portrait of Roberto Roach"
          loading="lazy"
          class="absolute inset-x-0 bottom-0 h-full w-full object-contain object-bottom"
        />
        <div
          class="absolute inset-0 z-[5] bg-gradient-to-t from-graphite-950/60 via-transparent to-transparent"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 z-10 flex items-center justify-between p-5 font-mono text-[10px] uppercase tracking-widest text-graphite-300"
        >
          <span>{SITE.location}</span>
          <span class="flex items-center gap-2 text-signal-400">
            <span class="status-led"></span>Active
          </span>
        </div>
      </div>

      <div class="reveal reveal-1">
        <div class="mono-label mb-4">Short-form biography</div>
        <h2
          class="mb-8 font-display text-[clamp(2rem,4vw,3.2rem)] font-bold leading-[1.02] tracking-tightest"
        >
          A working <em class="text-signal-gradient not-italic">document.</em>
        </h2>
        <div class="space-y-5 text-[17px] leading-[1.75] text-graphite-100">
          <p>
            I run <strong>RAR Technologies</strong> — electronics repair, websites, and advertising out
            of a single studio in Houston. It started at the bench, diagnosing phones and laptops, and
            grew into web and brand work for the same kinds of clients.
          </p>
          <p>
            I coached the <strong>Odyssey of the Mind</strong> team that won Worlds. I judge
            <strong>VEX IQ</strong> competitions across Texas. I've taught robotics and code (Python,
            Java, C++, Lua) at <strong>iCode</strong>. On weekends I translate legal documents
            between Spanish and English.
          </p>
          <p>
            In the fall I head to <strong>Penn State</strong> for electrical engineering — class of 2030.
            Circuits, robotics, embedded systems: the formal version of what I've been teaching myself
            out of the repair bench.
          </p>
          <p>
            Everything on this site is real. Where I don't have a detail verified, it's labeled
            <span
              class="rounded border border-graphite-700 bg-graphite-900 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-signal-400"
              >TODO</span
            >
            instead of made up. It'll get filled in as records surface.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Fast facts */}
  <section class="px-[var(--gutter)] py-24">
    <div class="mx-auto max-w-content">
      <div class="mb-14 grid grid-cols-1 items-baseline gap-6 md:grid-cols-[220px_1fr]">
        <div class="mono-label reveal">F · Fast facts</div>
        <h2
          class="reveal reveal-1 font-display text-[clamp(2rem,4.5vw,3.4rem)] font-bold leading-[1.02] tracking-tightest"
        >
          The verified <em class="text-signal-gradient not-italic">record.</em>
        </h2>
      </div>

      <dl class="grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
        <div class="reveal border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Base</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">
            Houston, TX
          </dd>
          <p class="mt-2 text-sm text-graphite-300">{SITE.coords}</p>
        </div>
        <div class="reveal reveal-1 border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Studio</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">
            RAR Technologies
          </dd>
          <p class="mt-2 text-sm text-graphite-300">Repair · Web · Advertising</p>
        </div>
        <div class="reveal reveal-2 border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Next</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">Penn State</dd>
          <p class="mt-2 text-sm text-graphite-300">Electrical Engineering · Class of 2030</p>
        </div>
        <div class="reveal border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Languages</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">EN · ES</dd>
          <p class="mt-2 text-sm text-graphite-300">Bilingual (fluent)</p>
        </div>
        <div class="reveal reveal-1 border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Coach</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">
            OM · World Finals
          </dd>
          <p class="mt-2 text-sm text-graphite-300">1st place · Odyssey of the Mind</p>
        </div>
        <div class="reveal reveal-2 border-t border-graphite-800 pt-6">
          <dt class="mono-label mb-3">Judge</dt>
          <dd class="font-display text-2xl font-bold leading-tight text-graphite-50">VEX IQ</dd>
          <p class="mt-2 text-sm text-graphite-300">Texas competitions</p>
        </div>
      </dl>
    </div>
  </section>

  {/* Coursework — verified from existing bio */}
  <section class="px-[var(--gutter)] py-24">
    <div class="mx-auto max-w-content">
      <div class="mb-14 grid grid-cols-1 items-baseline gap-6 md:grid-cols-[220px_1fr]">
        <div class="mono-label reveal">C · Coursework</div>
        <h2
          class="reveal reveal-1 font-display text-[clamp(2rem,4.5vw,3.4rem)] font-bold leading-[1.02] tracking-tightest"
        >
          What I've studied <em class="text-signal-gradient not-italic">outside of class.</em>
        </h2>
      </div>

      <ul class="reveal grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">Rice</div>
          <div class="text-lg font-medium text-graphite-50">Physics: Electromagnetism</div>
        </li>
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">Johns Hopkins</div>
          <div class="text-lg font-medium text-graphite-50">Precalc → Data & Modeling</div>
        </li>
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">IBM</div>
          <div class="text-lg font-medium text-graphite-50">Intro to Software Engineering</div>
        </li>
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">IBM</div>
          <div class="text-lg font-medium text-graphite-50">Intro to AI</div>
        </li>
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">Google</div>
          <div class="text-lg font-medium text-graphite-50">Cybersecurity Foundations</div>
        </li>
        <li class="rounded-2xl border border-graphite-800 bg-graphite-900 p-5">
          <div class="mono-label mb-2 text-signal-400">HKUST</div>
          <div class="text-lg font-medium text-graphite-50">
            Python & Statistics for Financial Analysis
          </div>
        </li>
      </ul>
    </div>
  </section>

  {/* Contact bump */}
  <section class="bg-radial-signal relative overflow-hidden px-[var(--gutter)] py-28 text-center">
    <div class="bg-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-2xl">
      <div class="mono-label mb-6 flex items-center justify-center gap-2.5">
        <span class="status-led"></span>Reach out
      </div>
      <h2
        class="mb-6 font-display text-[clamp(2.4rem,6vw,4.5rem)] font-extrabold leading-[0.95] tracking-tightest"
      >
        Say <em class="text-signal-gradient not-italic">hi.</em>
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/contact/" class="btn btn-primary"> Get in touch </a>
        <a href={`mailto:${SITE.email}`} class="btn">Email direct</a>
      </div>
    </div>
  </section>
</BaseLayout>
